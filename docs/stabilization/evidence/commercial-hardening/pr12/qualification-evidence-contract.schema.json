        "expectedSqlstate",
        "expectedRowCount",
        "observedHttpStatus",
        "observedSqlstate",
        "observedRowCount",
        "expectedAclOutcome",
        "expectedRlsOutcome",
        "observedAclOutcome",
        "observedRlsOutcome",
        "aclVerdict",
        "rlsVerdict",
        "status",
        "evidence"
      ],
      "properties": {
