        "targetTenant": { "type": "string" },
        "tenantBoundary": { "type": "string" },
        "target": { "type": "string" },
        "operation": { "type": "string" },
        "expectedHttpStatus": { "type": ["integer", "string"] },
        "expectedSqlstate": { "type": "string" },
        "expectedRowCount": { "type": ["integer", "string"] },
        "observedHttpStatus": { "type": ["integer", "string"] },
        "observedSqlstate": { "type": "string" },
        "observedRowCount": { "type": ["integer", "string"] },
        "expectedAclOutcome": { "type": "string" },
        "expectedRlsOutcome": { "type": "string" },
        "observedAclOutcome": { "type": "string" },
        "observedRlsOutcome": { "type": "string" },
        "aclVerdict": { "enum": ["PASS", "FAIL", "NOT_APPLICABLE"] },
        "rlsVerdict": { "enum": ["PASS", "FAIL", "NOT_APPLICABLE"] },
