        "p99Ms": { "type": ["number", "null"] },
        "minimumThroughputPerSecond": { "type": ["number", "null"] },
        "maximum5xxRate": { "type": ["number", "null"] },
        "maximumTimeoutRate": { "type": ["number", "null"] },
        "maximumCpuPercent": { "type": ["number", "null"] },
        "minimumPoolHeadroomPercent": { "type": ["number", "null"] },
        "maximumLockWaitMs": { "type": ["number", "null"] },
        "maximumWalBytes": { "type": ["number", "null"] },
        "maximumMigrationDurationSeconds": { "type": ["number", "null"] }
      }
    },
    "hostedSloObserved": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "p95Ms",
        "p99Ms",
        "throughputPerSecond",
        "rate5xx",
        "timeoutRate",
        "cpuPercent",
        "poolHeadroomPercent",
        "lockWaitMs",
        "walBytes",
        "migrationDurationSeconds"
      ],
      "properties": {
        "p95Ms": { "type": ["number", "null"] },
        "p99Ms": { "type": ["number", "null"] },
        "throughputPerSecond": { "type": ["number", "null"] },
        "rate5xx": { "type": ["number", "null"] },
        "timeoutRate": { "type": ["number", "null"] },
        "cpuPercent": { "type": ["number", "null"] },
        "poolHeadroomPercent": { "type": ["number", "null"] },
        "lockWaitMs": { "type": ["number", "null"] },
        "walBytes": { "type": ["number", "null"] },
        "migrationDurationSeconds": { "type": ["number", "null"] }
      }
    },
    "directRoleResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "caseId",
        "role",
        "operation",
        "expected",
        "observed",
        "aclVerdict",
        "rlsVerdict",
        "status",
        "evidence"
      ],
      "properties": {
        "caseId": { "type": "string" },
        "role": { "enum": ["anon", "authenticated", "service_role"] },
        "operation": { "type": "string" },
        "expected": { "type": "string" },
        "observed": { "type": "string" },
        "aclVerdict": { "enum": ["PASS", "FAIL", "NOT_APPLICABLE"] },
        "rlsVerdict": { "enum": ["PASS", "FAIL", "NOT_APPLICABLE"] },
        "status": { "$ref": "#/$defs/status" },
        "evidence": { "type": "array", "items": { "type": "string" } }
      }
    },
    "securityMatrixRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "caseId",
        "role",
        "actor",
        "jwtCase",
        "sourceTenant",
        "targetTenant",
        "tenantBoundary",
        "target",
        "operation",
