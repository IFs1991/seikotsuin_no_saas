            "evidence": { "minItems": 1 }
          }
        }
      ]
    },
    "metricResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "samples",
        "median",
        "limit",
        "unit",
        "status",
        "evidence"
      ],
      "properties": {
        "id": { "type": "string" },
        "samples": { "type": "array", "items": { "type": "number" } },
        "median": { "type": ["number", "null"] },
        "limit": { "type": ["number", "null"] },
        "unit": { "type": "string" },
        "status": { "$ref": "#/$defs/status" },
        "evidence": { "type": "array", "items": { "type": "string" } }
      }
    },
    "namedResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "status", "evidence"],
      "properties": {
        "id": { "type": "string" },
        "status": { "$ref": "#/$defs/status" },
        "evidence": { "type": "array", "items": { "type": "string" } }
      }
    },
    "hostedSloThresholds": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "p95Ms",
        "p99Ms",
        "minimumThroughputPerSecond",
        "maximum5xxRate",
        "maximumTimeoutRate",
        "maximumCpuPercent",
        "minimumPoolHeadroomPercent",
