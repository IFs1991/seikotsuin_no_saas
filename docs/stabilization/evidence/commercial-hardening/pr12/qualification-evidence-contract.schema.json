    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "bytes", "sha256", "classification"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "bytes": { "type": ["integer", "null"], "minimum": 0 },
        "sha256": { "$ref": "#/$defs/sha256OrPlaceholder" },
        "classification": {
          "enum": ["PUBLIC_SANITIZED", "INTERNAL_NO_PII", "LOCAL_QUARANTINE"]
        }
      }
    },
    "concreteArtifact": {
      "allOf": [
        { "$ref": "#/$defs/artifact" },
        {
          "properties": {
            "path": { "$ref": "#/$defs/concreteString" },
            "bytes": { "type": "integer", "minimum": 0 },
            "sha256": { "$ref": "#/$defs/sha256" }
          }
        }
      ]
    }
  }
