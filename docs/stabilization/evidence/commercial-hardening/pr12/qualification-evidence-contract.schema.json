                  "contractSha256": { "$ref": "#/$defs/sha256" },
                  "workloadId": { "$ref": "#/$defs/concreteString" },
                  "concurrency": { "type": "integer", "minimum": 1 },
                  "sampleOrder": { "minItems": 1 },
                  "durationSeconds": {
                    "type": "number",
                    "exclusiveMinimum": 0
                  },
                  "status": { "const": "PASS" },
                  "evidence": { "minItems": 1 }
                }
              }
            }
          },
          "gates": {
            "minItems": 54,
            "items": {
              "properties": {
                "status": { "const": "PASS" },
                "evidence": { "minItems": 1 }
              }
            }
          },
          "securityMatrix": {
            "properties": {
              "matrixId": { "$ref": "#/$defs/concreteString" },
              "contractPath": { "$ref": "#/$defs/concreteString" },
              "contractSha256": { "$ref": "#/$defs/sha256" },
              "roles": { "minItems": 3 },
              "jwtCases": { "minItems": 7 },
              "tenantCrudCases": { "minItems": 4 },
              "rows": { "minItems": 1 },
              "serviceRoleBoundary": { "$ref": "#/$defs/passedGateResult" },
              "aclRlsIndependence": { "$ref": "#/$defs/passedGateResult" }
            }
          },
          "externalSideEffects": {
            "properties": {
              "mode": { "enum": ["DISABLED", "SANDBOXED"] },
              "duplicateCount": { "const": 0 },
              "evidence": { "minItems": 1 }
            }
          },
          "backup": {
            "properties": {
              "status": { "const": "PASS" },
              "method": { "$ref": "#/$defs/concreteString" },
              "scope": { "$ref": "#/$defs/concreteString" },
              "capturedAt": { "$ref": "#/$defs/concreteString" },
              "sourceWatermark": { "$ref": "#/$defs/concreteString" },
              "artifactPath": { "$ref": "#/$defs/concreteString" },
              "artifactSha256": { "$ref": "#/$defs/sha256" },
              "evidence": { "minItems": 1 }
            }
          },
          "restore": {
            "properties": {
              "status": { "const": "PASS" },
              "restoreSource": { "$ref": "#/$defs/concreteString" },
              "restorePoint": { "$ref": "#/$defs/concreteString" },
              "rtoStartEvent": { "$ref": "#/$defs/concreteString" },
              "rtoEndEvent": { "$ref": "#/$defs/concreteString" },
              "rtoMeasurementClockAndSource": {
                "$ref": "#/$defs/concreteString"
              },
              "rpoWatermarkDefinition": { "$ref": "#/$defs/concreteString" },
              "rpoObservationEvent": { "$ref": "#/$defs/concreteString" },
              "rpoMeasurementClockAndSource": {
                "$ref": "#/$defs/concreteString"
              },
              "rtoThresholdSeconds": { "type": "number", "minimum": 0 },
              "rpoThresholdSeconds": { "type": "number", "minimum": 0 },
              "rtoSeconds": { "type": "number", "minimum": 0 },
              "rpoSeconds": { "type": "number", "minimum": 0 },
              "evidence": { "minItems": 1 }
            }
          },
          "postRestore": {
            "properties": {
              "schemaParity": { "$ref": "#/$defs/passedGateResult" },
              "dataParity": { "$ref": "#/$defs/passedGateResult" },
              "tenantIsolation": { "$ref": "#/$defs/passedGateResult" },
              "authBoundary": { "$ref": "#/$defs/passedGateResult" },
              "dataApiBoundary": { "$ref": "#/$defs/passedGateResult" },
              "graphQlBoundary": { "$ref": "#/$defs/passedGateResult" }
            }
          },
          "ownership": {
            "properties": {
              "owner": { "$ref": "#/$defs/concreteString" },
              "approver": { "$ref": "#/$defs/concreteString" },
              "stagingOperator": { "$ref": "#/$defs/concreteString" },
              "incidentOwner": { "$ref": "#/$defs/concreteString" }
            }
          },
          "privacyScan": {
            "properties": {
              "status": { "const": "PASS" },
              "scannedAt": { "$ref": "#/$defs/concreteString" },
              "findingCount": { "const": 0 },
              "machineScanCommandId": { "$ref": "#/$defs/concreteString" },
              "machineScanEvidence": { "minItems": 1 },
              "manualReviewStatus": { "const": "PASS" },
              "manualReviewer": { "$ref": "#/$defs/concreteString" },
              "manualReviewedAt": { "$ref": "#/$defs/concreteString" },
              "manualReviewEvidence": { "minItems": 1 }
            }
          },
          "expiresAt": {
            "allOf": [
              { "$ref": "#/$defs/concreteString" },
              { "type": "string", "format": "date-time" }
            ]
          }
        }
      }
    }
  ],
  "$defs": {
    "status": {
      "enum": ["PASS", "FAIL", "NOT_RUN", "PASS_WITH_RISK", "NOT_APPLICABLE"]
    },
    "gitCommit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "sha256OrPlaceholder": {
      "oneOf": [{ "$ref": "#/$defs/sha256" }, { "const": "NOT_CAPTURED" }]
    },
    "concreteString": {
      "type": "string",
      "minLength": 1,
      "not": {
        "enum": ["NOT_CAPTURED", "NOT_RUN", "UNASSIGNED", "NOT_APPLICABLE"]
      }
    },
    "gateResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "evidence"],
      "properties": {
        "status": { "$ref": "#/$defs/status" },
        "evidence": { "type": "array", "items": { "type": "string" } }
      }
    },
    "passedGateResult": {
      "allOf": [
        { "$ref": "#/$defs/gateResult" },
        {
          "properties": {
            "status": { "const": "PASS" },
            "evidence": { "minItems": 1 }
          }
        }
      ]
    },
    "supportedGateResult": {
      "allOf": [
        { "$ref": "#/$defs/gateResult" },
        {
