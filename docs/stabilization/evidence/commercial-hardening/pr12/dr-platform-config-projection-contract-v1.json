      "queries": [
        {
          "id": "storage_bucket_row_count",
          "sql": "select count(*)::bigint as storage_bucket_row_count from storage.buckets;"
        },
        {
          "id": "storage_object_metadata_row_count",
          "sql": "select count(*)::bigint as storage_object_metadata_row_count from storage.objects;"
        },
        {
          "id": "custom_roles_requiring_passwords",
          "sql": "select r.rolname from pg_catalog.pg_authid as r where r.rolcanlogin and r.rolpassword is not null and r.rolname !~ '^(anon|authenticated|authenticator|dashboard_user|pgbouncer|postgres|service_role|supabase_)' order by r.rolname;"
        },
        {
          "id": "extension_catalog",
          "sql": "select e.extname, e.extversion from pg_catalog.pg_extension as e order by e.extname;"
        },
        {
          "id": "normalized_database_settings",
          "sql": "select s.name, s.setting, s.unit, s.source from pg_catalog.pg_settings as s where s.name in ('max_connections','search_path','shared_preload_libraries','ssl','wal_level') order by s.name;"
        },
        {
          "id": "realtime_publication_tables",
          "sql": "select n.nspname || '.' || c.relname as relation from pg_catalog.pg_publication as p join pg_catalog.pg_publication_rel as pr on pr.prpubid = p.oid join pg_catalog.pg_class as c on c.oid = pr.prrelid join pg_catalog.pg_namespace as n on n.oid = c.relnamespace where p.pubname = 'supabase_realtime' order by relation;"
        }
      ],
