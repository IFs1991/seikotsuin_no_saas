# Production Environment Variables for Vercel

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-production-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-production-service-role-key

# Application
NODE_ENV=production
NEXT_PUBLIC_APP_ENV=production
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
NEXT_PUBLIC_APP_VERSION=0.1.0-pilot
NEXT_PUBLIC_BUILD_DATE=2026-03-27
NEXT_PUBLIC_DEFAULT_CLINIC_ID=uuid-of-default-clinic
NEXT_PUBLIC_LP_FORM_URL=
NEXT_PUBLIC_DEFAULT_TIMEZONE=Asia/Tokyo
NEXT_PUBLIC_CLINIC_GROUP_NAME=整骨院グループ

# Security
ENCRYPTION_KEY=your-production-encryption-key
JWT_SECRET=your-production-jwt-secret
CSP_ROLLOUT_PHASE=full-enforce
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-production-turnstile-site-key
TURNSTILE_SECRET_KEY=your-production-turnstile-secret-key
TURNSTILE_BYPASS_NON_PRODUCTION=false

# Monitoring
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
LOG_LEVEL=info

# Feature Flags
NEXT_PUBLIC_ENABLE_CHAT=false
NEXT_PUBLIC_ENABLE_AI_INSIGHTS=false
NEXT_PUBLIC_ENABLE_ADMIN_FEATURES=true
NEXT_PUBLIC_PILOT_MODE=true
NEXT_PUBLIC_MAX_CLINICS=3
NEXT_PUBLIC_ENABLE_LIFF_BOOKING=false

# LINE (required when NEXT_PUBLIC_ENABLE_LIFF_BOOKING=true)
LINE_CREDENTIALS_ENCRYPTION_KEY=

# Upstash Redis
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_redis_token

# Gemini AI
GEMINI_API_KEY=
NEXT_PUBLIC_GEMINI_MODEL=gemini-2.0-flash-exp

# Resend メール設定
RESEND_API_KEY=your-production-resend-api-key
RESEND_FROM_DEFAULT=Tiramisu <no-reply@your-verified-domain.example>
RESEND_FROM_NOTIFY=Tiramisu通知 <notify@mail.tiramisu-app.com>
RESEND_REPLY_TO=support@tiramisu-app.com
RESEND_WEBHOOK_SECRET=your-production-resend-webhook-secret

# Resend SMTP (Supabase Auth用)
RESEND_SMTP_HOST=smtp.resend.com
RESEND_SMTP_PORT=587
RESEND_SMTP_USERNAME=resend
RESEND_SMTP_PASSWORD=

# Internal cron
CRON_SECRET=your-production-cron-secret
INTERNAL_API_SECRET=

# Stripe Billing (default off until production rollout)
ENABLE_BILLING=false
NEXT_PUBLIC_ENABLE_BILLING=false
BILLING_ENABLED_PLANS=single_clinic,group
ENABLE_BILLING_TENANT_GUARD=false
ENABLE_BILLING_OVERRIDES=false
ENABLE_BILLING_INTERNAL_ROUTES=false
ENABLE_BILLING_UPGRADE=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_SINGLE_CLINIC_ID=
STRIPE_PRICE_GROUP_BASE_ID=
STRIPE_PRICE_STORE_ADDON_ID=

# Optional Notification Settings
SLACK_WEBHOOK_URL=
SMTP_SERVER=
SMTP_USER=
SMTP_PASSWORD=
