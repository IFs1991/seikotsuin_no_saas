# Production Environment Variables for Vercel

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-production-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-production-service-role-key

# Application
NODE_ENV=production
NEXT_PUBLIC_APP_ENV=production
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
NEXT_PUBLIC_APP_VERSION=0.1.0-pilot
NEXT_PUBLIC_BUILD_DATE=2026-03-27
NEXT_PUBLIC_DEFAULT_CLINIC_ID=uuid-of-default-clinic
NEXT_PUBLIC_DEFAULT_TIMEZONE=Asia/Tokyo
NEXT_PUBLIC_CLINIC_GROUP_NAME=整骨院グループ

# Security
ENCRYPTION_KEY=your-production-encryption-key
JWT_SECRET=your-production-jwt-secret
CSP_ROLLOUT_PHASE=full-enforce

# Monitoring
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Feature Flags
NEXT_PUBLIC_ENABLE_CHAT=false
NEXT_PUBLIC_ENABLE_AI_INSIGHTS=false
NEXT_PUBLIC_ENABLE_ADMIN_FEATURES=true
NEXT_PUBLIC_PILOT_MODE=true
NEXT_PUBLIC_MAX_CLINICS=3

# Upstash Redis
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_redis_token

# Gemini AI
GEMINI_API_KEY=
NEXT_PUBLIC_GEMINI_MODEL=gemini-2.0-flash-exp

# Resend メール設定
RESEND_API_KEY=
RESEND_FROM_DEFAULT=Tiramisu <no-reply@mail.tiramisu-app.com>
RESEND_FROM_NOTIFY=Tiramisu通知 <notify@mail.tiramisu-app.com>
RESEND_REPLY_TO=support@tiramisu-app.com
RESEND_WEBHOOK_SECRET=

# Resend SMTP (Supabase Auth用)
RESEND_SMTP_HOST=smtp.resend.com
RESEND_SMTP_PORT=587
RESEND_SMTP_USERNAME=resend
RESEND_SMTP_PASSWORD=

# Internal cron
CRON_SECRET=

# Optional Notification Settings
SLACK_WEBHOOK_URL=
SMTP_SERVER=
SMTP_USER=
SMTP_PASSWORD=
