# =============================================================================
# E2Eテスト用環境変数
# @spec docs/stabilization/spec-staff-invite-e2e-stability-v0.1.md
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase設定（ローカル開発用）
# -----------------------------------------------------------------------------
# supabase start で起動したローカルSupabaseのURL
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54331
# supabase status で取得できるanon key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_local_anon_key
# supabase status で取得できるservice_role key
SUPABASE_SERVICE_ROLE_KEY=your_local_service_role_key

# -----------------------------------------------------------------------------
# アプリケーション設定（E2E）
# -----------------------------------------------------------------------------
# E2Eテストで使用するアプリケーションURL
# supabase/config.toml の auth.site_url と一致させること
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000
NEXT_PUBLIC_APP_VERSION=0.1.0-pilot
NEXT_PUBLIC_BUILD_DATE=2026-03-27
NEXT_PUBLIC_DEFAULT_CLINIC_ID=your_local_default_clinic_uuid
NEXT_PUBLIC_LP_FORM_URL=
NEXT_PUBLIC_DEFAULT_TIMEZONE=Asia/Tokyo
NEXT_PUBLIC_CLINIC_GROUP_NAME=整骨院グループ

# Playwright baseURL（playwright.config.ts でも設定可能）
PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000

# -----------------------------------------------------------------------------
# E2Eテスト専用フラグ
# -----------------------------------------------------------------------------
# E2E_INVITE_MODE=skip: スタッフ招待時に inviteUserByEmail をスキップし、
#   staff_invitesテーブルへのINSERTのみで成功応答を返す。
#   これにより、Supabase Authのメール送信待ちによるハングを回避できる。
#   本番環境(NODE_ENV=production)では無効化される。
E2E_INVITE_MODE=skip

# -----------------------------------------------------------------------------
# テスト用認証情報
# -----------------------------------------------------------------------------
# E2Eテストで使用するadminユーザーの認証情報
E2E_ADMIN_EMAIL=admin@example.com
E2E_ADMIN_PASSWORD=testpassword123

# E2Eテストで使用するstaffユーザーの認証情報
E2E_STAFF_EMAIL=staff@example.com
E2E_STAFF_PASSWORD=testpassword123

# -----------------------------------------------------------------------------
# 開発環境設定
# -----------------------------------------------------------------------------
NODE_ENV=test
NEXT_PUBLIC_APP_ENV=test

# -----------------------------------------------------------------------------
# セキュリティ・監視設定
# -----------------------------------------------------------------------------
ENCRYPTION_KEY=your_test_encryption_key
JWT_SECRET=your_test_jwt_secret
CSP_ROLLOUT_PHASE=report-only
SENTRY_DSN=
LOG_LEVEL=error

# -----------------------------------------------------------------------------
# 機能フラグ
# -----------------------------------------------------------------------------
NEXT_PUBLIC_ENABLE_CHAT=true
NEXT_PUBLIC_ENABLE_AI_INSIGHTS=true
NEXT_PUBLIC_ENABLE_ADMIN_FEATURES=true
NEXT_PUBLIC_PILOT_MODE=false
NEXT_PUBLIC_MAX_CLINICS=46
ENABLE_BILLING=false
NEXT_PUBLIC_ENABLE_BILLING=false
BILLING_ENABLED_PLANS=single_clinic,group
ENABLE_BILLING_TENANT_GUARD=false
ENABLE_BILLING_OVERRIDES=false
ENABLE_BILLING_INTERNAL_ROUTES=false
ENABLE_BILLING_UPGRADE=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_SINGLE_CLINIC_ID=
STRIPE_PRICE_GROUP_BASE_ID=
STRIPE_PRICE_STORE_ADDON_ID=
INTERNAL_API_SECRET=
CRON_SECRET=

# -----------------------------------------------------------------------------
# Upstash Redis
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
