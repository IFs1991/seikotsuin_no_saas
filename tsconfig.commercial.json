{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "incremental": false,
    "strict": true
  },
  "include": [
    "next-env.d.ts",
    "src/app/api/**/*.ts",
    "src/app/api/**/*.tsx",
    "src/lib/security/**/*.ts",
    "src/lib/security/**/*.tsx",
    "src/@types/**/*.d.ts",
    "src/types/**/*.d.ts",
    "src/lib/api-helpers.ts",
    "src/lib/route-helpers.ts",
    "src/lib/auth/**/*.ts",
    "src/lib/billing/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "out",
    "dist",
    "build",
    "src/__tests__",
    "src/legacy"
  ]
}
