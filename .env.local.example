# Supabase設定
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# アプリケーション設定
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_VERSION=0.1.0-pilot
NEXT_PUBLIC_BUILD_DATE=2026-03-27
NEXT_PUBLIC_DEFAULT_CLINIC_ID=your_default_clinic_uuid

# 開発環境設定
NODE_ENV=development
NEXT_PUBLIC_APP_ENV=development

# 医療システム固有の設定
NEXT_PUBLIC_CLINIC_GROUP_NAME=整骨院グループ
NEXT_PUBLIC_MAX_CLINICS=46
NEXT_PUBLIC_DEFAULT_TIMEZONE=Asia/Tokyo

# セキュリティ設定
ENCRYPTION_KEY=your_encryption_key_for_sensitive_data
JWT_SECRET=your_jwt_secret
CSP_ROLLOUT_PHASE=report-only

# 監視設定
SENTRY_DSN=

# Upstash Redis設定
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Gemini AI設定
GEMINI_API_KEY=your_gemini_api_key
NEXT_PUBLIC_GEMINI_MODEL=gemini-2.0-flash-exp

# Resend メール設定
RESEND_API_KEY=
RESEND_FROM_DEFAULT=Tiramisu <no-reply@mail.tiramisu-app.com>
RESEND_FROM_NOTIFY=Tiramisu通知 <notify@mail.tiramisu-app.com>
RESEND_REPLY_TO=support@tiramisu-app.com
RESEND_WEBHOOK_SECRET=

# Resend SMTP (Supabase Auth用)
RESEND_SMTP_HOST=smtp.resend.com
RESEND_SMTP_PORT=587
RESEND_SMTP_USERNAME=resend
RESEND_SMTP_PASSWORD=

# Internal cron
CRON_SECRET=
INTERNAL_API_SECRET=

# Stripe Billing (default off)
ENABLE_BILLING=false
NEXT_PUBLIC_ENABLE_BILLING=false
BILLING_ENABLED_PLANS=single_clinic,group
ENABLE_BILLING_TENANT_GUARD=false
ENABLE_BILLING_OVERRIDES=false
ENABLE_BILLING_INTERNAL_ROUTES=false
ENABLE_BILLING_UPGRADE=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_SINGLE_CLINIC_ID=
STRIPE_PRICE_GROUP_BASE_ID=
STRIPE_PRICE_STORE_ADDON_ID=

# 機能フラグ
NEXT_PUBLIC_ENABLE_CHAT=true
NEXT_PUBLIC_ENABLE_AI_INSIGHTS=true
NEXT_PUBLIC_ENABLE_ADMIN_FEATURES=true
NEXT_PUBLIC_PILOT_MODE=false

# Mobile UIUX production shell / write pilot flags
MOBILE_UIUX_ENABLED=false
MOBILE_UIUX_USE_DB_ENTITLEMENTS=false
MOBILE_UIUX_REAL_DATA_ENABLED=false
MOBILE_UIUX_WRITE_ENABLED=false
MOBILE_UIUX_DAILY_REPORT_WRITE_ENABLED=false
MOBILE_UIUX_RESERVATION_WRITE_ENABLED=false
MOBILE_UIUX_SETTINGS_WRITE_ENABLED=false
MOBILE_UIUX_ALLOWED_CLINIC_IDS=
MOBILE_UIUX_ALLOWED_ROLES=admin,clinic_admin,manager,therapist,staff
