{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm ci",
  "framework": "nextjs",
  "env": {
    "NODE_ENV": "production",
    "CSP_ROLLOUT_PHASE": "full-enforce",
    "MOBILE_UIUX_ENABLED": "true",
    "MOBILE_UIUX_REAL_DATA_ENABLED": "true",
    "MOBILE_UIUX_WRITE_ENABLED": "false",
    "MOBILE_UIUX_RESERVATION_WRITE_ENABLED": "false",
    "MOBILE_UIUX_DAILY_REPORT_WRITE_ENABLED": "false",
    "MOBILE_UIUX_SETTINGS_WRITE_ENABLED": "false"
  },
  "functions": {
    "src/app/api/*/route.ts": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/internal/process-email-outbox",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/internal/process-line-outbox",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/internal/reservation-reminders",
      "schedule": "*/5 * * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        }
      ]
    }
  ]
}
